<robot
  name="xArm1S">

    <link name="base_plate">
        <visual>
            <origin xyz="0 0 0.0325" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.055" length="0.065"/>
            </geometry>
            <material name="Cyan">
                <color rgba="0 1.0 1.0 1.0"/>
            </material>
        </visual>
    </link>

    <link name="plate_to_servo">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.055" length="0.00001"/>
            </geometry>
            <material name="Green">
                <color rgba="0.2 1.0 0.2 1.0"/>
            </material>
        </visual>
    </link>

    <link name="arm1">
        <visual>
            <origin xyz="0 0 0.0505" rpy="0 0 0"/>
            <geometry>
                <box size="0.032 0.057 0.101"/>
            </geometry>
            <material name="Cyan">
                <color rgba="0 1.0 1.0 1.0"/>
            </material>
        </visual>
    </link>
    <link name="arm2">
        <visual>
            <origin xyz="0 0 0.0475" rpy="0 0 0"/>
            <geometry>
                <box size="0.023 0.027 0.095"/>
            </geometry>
            <material name="Cyan">
                <color rgba="0 1.0 1.0 1.0"/>
            </material>
        </visual>
    </link>

    <link name="arm3">
        <visual>
            <origin xyz="0 0 0.0279" rpy="0 0 0"/>
            <geometry>
                <box size="0.0404 0.0416 0.0558"/>
            </geometry>
            <material name="Cyan">
                <color rgba="0 1.0 1.0 1.0"/>
            </material>
        </visual>
    </link>

    <link name="cutter" />
    <link name="wire">
        <visual>
            <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
            <geometry>
                <cylinder radius="0.001" length="0.160"/>
            </geometry>
            <material name="Red">
                <color rgba="1.0 0.2 0.2 1.0"/>
            </material>
        </visual>
    </link>

    <!-- First joint connects the base frame to the rotating plate. This rotates the entire arm about the z-axis-->
    <joint name="j1" type="revolute">
        <parent link="base_plate"/>
        <child link="plate_to_servo"/>
        <origin xyz="0 0 0.065" rpy="0 0 0" />
        <axis xyz="0 0 1.0" />
        <limit effort="1.4709975" velocity="4.75998886909" lower="-2.09439510239" upper="2.09439510239" />
    </joint>

    <!-- Second joint is attached to the rotation plate and swivels the arm about the y-axis, the origin of its rotation
         axis is taken as the end of j1 for convenience-->
    <joint name="j2" type="revolute">
        <parent link="plate_to_servo"/>
        <child link="arm1"/>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <axis xyz="0 -1 0" />
        <limit effort="2.4516625" velocity="4.75998886909" lower="-2.09439510239" upper="2.09439510239" />
    </joint>

    <!-- Third joint is the elbow joint, rotating about the y-axis-->
    <joint name="j3" type="revolute">
        <parent link="arm1"/>
        <child link="arm2"/>
        <origin xyz="0 0 0.101" rpy="0 0 0" />
        <axis xyz="0 -1 0" />
        <limit effort="1.4709975" velocity="4.75998886909" lower="-2.09439510239" upper="2.09439510239" />
    </joint>

    <!-- Fourth joint is the wrist joint, rotating about the y-axis-->
    <joint name="j4" type="revolute">
        <parent link="arm2"/>
        <child link="arm3"/>
        <origin xyz="0 0 0.095" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1.4709975" velocity="4.75998886909" lower="-2.09439510239" upper="2.09439510239" />
    </joint>

    <!-- Fifth joint is the end effector joint and rotates about the z-axis-->
    <joint name="j5" type="revolute">
        <parent link="arm3"/>
        <child link="cutter"/>
        <origin xyz="0 0 0.0558" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1.4709975" velocity="4.75998886909" lower="-2.09439510239" upper="2.09439510239" />
    </joint>

    <!-- Ideally this joint would be appended on depending on what end effector is being used, but I haven't looked
    into how to do that yet-->
    <!-- Sixth joint is not really a joint, but instead is the coordinate frame aligning with the cutting wire-->
    <joint name="cutter_to_wire" type="fixed">
        <parent link="cutter"/>
        <child link="wire"/>
        <origin xyz="0.052 0 0.156" rpy="0 0 0" />
    </joint>

</robot>
